<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Fallback for builds WITHOUT an embedded provisioning profile: iCloud
	     entitlements are only honored when a profile carries them, and signing
	     them in without one yields a build where CloudKit fails at runtime
	     with a bare "not entitled". This file is App.entitlements minus the
	     iCloud keys. -->
	<!-- No sandbox on the app itself (it never had one); the app group grants
	     clean access to the widget snapshot container on macOS 15+, where
	     unentitled access to Group Containers can prompt or be denied. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>89LCRZKZ48.com.bakhod1r.sharingan</string>
	</array>
</dict>
</plist>
